# Neon Postgres — POOLED connection (host contains "-pooler"). Used by the app.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/homebuzz?sslmode=require"

# Neon Postgres — DIRECT connection (no "-pooler"). Used by drizzle-kit migrations.
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxx.region.aws.neon.tech/homebuzz?sslmode=require"

# NextAuth v5 secret — generate with: npx auth secret
AUTH_SECRET="your-secret-here"
